{
	"name": "xray",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.1.2",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=11.0.0"
	},
	"scripts": {
		"preinstall": "node -e \"if(!(process.env.npm_execpath||'').includes('pnpm')&&!(process.env.npm_config_user_agent||'').startsWith('pnpm/'))throw new Error('Use pnpm — see .claude/rules/supply-chain.md')\"",
		"prepare": "lefthook install",
		"check": "biome check",
		"check:fix": "biome check --write",
		"format": "biome format --write",
		"lint": "biome lint",
		"typecheck": "tsc --noEmit",
		"dev": "UID=$(id -u) GID=$(id -g) docker compose -f compose.dev.yaml up --build",
		"dev:down": "docker compose -f compose.dev.yaml down -v",
		"build": "bun run scripts/build.ts",
		"seed": "bun run scripts/seed.ts",
		"start": "bun src/server/main.ts",
		"docker:build": "docker build -t xray:local .",
		"docker:run": "docker run --rm -p 8080:8080 --env-file .env xray:local",
		"docker:smoke": "bash scripts/docker-smoke.sh",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"test": "bun test --isolate --path-ignore-patterns '**/src/client/**'",
		"test:watch": "bun test --isolate --watch --path-ignore-patterns '**/src/client/**'",
		"test:coverage": "bun test --isolate --coverage --path-ignore-patterns '**/src/client/**'"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@commitlint/cli": "^21.0.0",
		"@commitlint/config-conventional": "^21.0.0",
		"@happy-dom/global-registrator": "20.9.0",
		"@testing-library/react": "16.3.2",
		"@types/bun": "^1.3.13",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"drizzle-kit": "0.31.10",
		"happy-dom": "^20.9.0",
		"lefthook": "^2.1.6",
		"msw": "2.14.5",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@fontsource-variable/jetbrains-mono": "5.2.8",
		"@fontsource-variable/onest": "5.2.11",
		"@hono/standard-validator": "0.2.2",
		"@scalar/hono-api-reference": "0.10.14",
		"@tanstack/react-query": "5.100.9",
		"@tanstack/react-router": "1.169.2",
		"@valibot/to-json-schema": "1.7.0",
		"bun-plugin-tailwind": "0.1.2",
		"bunqueue": "2.7.12",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"drizzle-orm": "0.45.2",
		"hono": "4.12.18",
		"hono-openapi": "1.3.0",
		"ky": "2.0.2",
		"lucide-react": "1.14.0",
		"openapi-types": "12.1.3",
		"radix-ui": "1.4.3",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"tailwind-merge": "3.5.0",
		"tailwindcss": "4.3.0",
		"ts-pattern": "5.9.0",
		"tw-animate-css": "1.4.0",
		"valibot": "1.3.1"
	}
}
