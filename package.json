{
	"name": "xray",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.1.2",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=11.0.0"
	},
	"scripts": {
		"preinstall": "node -e \"if(!(process.env.npm_execpath||'').includes('pnpm')&&!(process.env.npm_config_user_agent||'').startsWith('pnpm/'))throw new Error('Use pnpm — see .claude/rules/supply-chain.md')\"",
		"prepare": "lefthook install",
		"check": "biome check",
		"check:fix": "biome check --write",
		"format": "biome format --write",
		"lint": "biome lint",
		"typecheck": "tsc --noEmit",
		"dev": "UID=$(id -u) GID=$(id -g) docker compose -f compose.dev.yaml up --build",
		"dev:down": "docker compose -f compose.dev.yaml down -v",
		"build": "vite build",
		"start": "bun src/server/server.ts",
		"docker:build": "docker build -t xray:local .",
		"docker:run": "docker run --rm -p 8080:8080 --env-file .env xray:local",
		"docker:smoke": "bash scripts/docker-smoke.sh",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"test": "pnpm test:vitest && pnpm test:store",
		"test:watch": "vitest",
		"test:vitest": "vitest run",
		"test:store": "bun test src/server/store/",
		"test:coverage": "pnpm test:coverage:vitest && pnpm test:coverage:store",
		"test:coverage:vitest": "vitest run --coverage",
		"test:coverage:store": "bun test --coverage src/server/store/"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@commitlint/cli": "^21.0.0",
		"@commitlint/config-conventional": "^21.0.0",
		"@testing-library/react": "16.3.2",
		"@types/bun": "^1.3.13",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"drizzle-kit": "0.31.10",
		"happy-dom": "^20.9.0",
		"lefthook": "^2.1.6",
		"msw": "2.14.5",
		"typescript": "^6.0.3",
		"vite": "8.0.11",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"drizzle-orm": "0.45.2",
		"hono": "4.12.18",
		"ky": "2.0.2",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"ts-pattern": "5.9.0",
		"valibot": "1.3.1"
	}
}
