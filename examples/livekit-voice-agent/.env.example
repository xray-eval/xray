# Copy to `.env` (gitignored at the repo root) and fill in.
#
# Only one secret is required: a Google Generative AI ("Gemini") API
# key with access to the Gemini Live realtime model. Get one from
# https://aistudio.google.com/app/apikey.
#
# LiveKit dev-mode keys are hardcoded in compose.yaml — they only
# accept connections on the compose-internal network so they're safe
# to ship in source.
GEMINI_API_KEY=
