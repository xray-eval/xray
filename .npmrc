# Pinned single registry — alternate registries must be added per-scope here, explicitly.
registry=https://registry.npmjs.org/

# Enforce package.json "engines" — wrong Node/pnpm version fails install.
engine-strict=true

# Belt-and-braces: scripts are off globally, allowBuilds in pnpm-workspace.yaml is the allowlist.
ignore-scripts=true

# Sigstore provenance for anything we publish.
provenance=true

# Fail audits at moderate or higher.
audit-level=moderate
