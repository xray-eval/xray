# Dependencies
node_modules/
.pnpm-store/

# Bun build output
dist/
*.local

# Build caches
*.tsbuildinfo

# VitePress docs cache (build output under docs/.vitepress/dist/ is covered by dist/ above)
docs/.vitepress/cache/

# Test & coverage
coverage/
.nyc_output/

# Env & secrets
.env
.env.*
!.env.example
*.pem
*.key

# Python bytecode + caches (xray-py SDK)
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# Logs
*.log
pnpm-debug.log*

# SQLite transient WAL files next to committed snapshot DB
snapshot/*.db-shm
snapshot/*.db-wal

# Editor / OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Claude Code subagent worktrees — git worktrees the Agent tool spins up
# under `isolation: "worktree"`. Real working trees with their own checkouts;
# they shouldn't pollute git status here OR trip biome's config discovery
# (their full biome.json copy makes biome see two competing root configs).
.claude/worktrees/
